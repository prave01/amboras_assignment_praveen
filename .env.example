# ------------------------------------------------------------
# API (apps/api)
# ------------------------------------------------------------
NODE_ENV=development
PORT=8080

DATABASE_URL=postgresql://amboras:amboras_secret@localhost:5432/amboras_db

REDIS_HOST=localhost
REDIS_PORT=6379

# Comma-separated list of allowed frontend origins
# Example: CORS_ORIGINS=http://localhost:3000,http://localhost:3002
CORS_ORIGINS=http://localhost:3000

# JWT (currently secret is hardcoded in code; expires-in is env driven)
JWT_EXPIRESIN=4h


# ------------------------------------------------------------
# Analytics frontend (apps/analytics)
# ------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1


# ------------------------------------------------------------
# Simulator (apps/simulator)
# ------------------------------------------------------------
API_BASE_URL=http://localhost:8080
EVENTS_PER_SECOND=50
BATCH_SIZE=20
REALISTIC_MODE=true