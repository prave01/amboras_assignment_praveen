{
  "name": "amboras",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:seed": "pnpm --filter @repo/api exec pnpm run db:seed",
    "db:migrate": "pnpm --filter @repo/api exec pnpm run db:migrate",
    "db:generate": "pnpm --filter @repo/api exec pnpm run db:generate",
    "db:push": "pnpm --filter @repo/api exec pnpm run db:push",
    "db:studio": "pnpm --filter @repo/api exec pnpm run db:studio"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "prettier-plugin-classnames": "^0.10.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.2",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
